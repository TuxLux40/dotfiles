# Keep secrets out of git

# Dotenv files (global)
.env
.env.local
.envrc
*.env
*.env.local
**/.env
**/.env.local
**/*.env

# But keep example templates tracked
!.env.example
!**/.env.example
!*.env.example

# atuin install receipt (regenerated by atuin's installer; runtime metadata, not config)
atuin/.config/atuin/atuin-receipt.json
